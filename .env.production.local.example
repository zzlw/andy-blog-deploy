# ===================== 生产敏感配置模板 =====================
# 服务器上执行：cp .env.production.local.example .env.production.local
# 填写真实值后 chmod 600 .env.production.local（该文件已被 git 忽略）

# JWT 签名密钥（长随机串，可用 openssl rand -base64 48 生成）
JWT_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# 空库启动时自动创建的超管密码（6~32 位，含字母和数字）
ADMIN_INIT_PASSWORD=CHANGE_ME_StrongPass1

# S3 / 阿里云 OSS 访问密钥
S3_ACCESS_KEY_ID=CHANGE_ME
S3_SECRET_ACCESS_KEY=CHANGE_ME

# AI 知识库 Webhook 签名密钥（长随机串，须与 AI 服务侧 WEBHOOK_SECRET 完全一致）
# 生成：openssl rand -hex 32；不配置则禁用 AI 知识库同步
WEBHOOK_SECRET=CHANGE_ME_LONG_RANDOM_STRING

# 阿里云 RAM AccessKey（DNS-01 验证 + CDN 证书推送，最小权限：
# AliyunDNSFullAccess + cdn:SetCdnDomainSSLCertificate 或 AliyunCDNFullAccess）
ALI_KEY=CHANGE_ME
ALI_SECRET=CHANGE_ME

# 自托管 Umami 访客统计密钥
# Postgres 密码（生成：openssl rand -hex 24）
UMAMI_DB_PASSWORD=CHANGE_ME
# Umami APP_SECRET（会话签名/哈希盐，生成：openssl rand -hex 32）
UMAMI_APP_SECRET=CHANGE_ME_LONG_RANDOM_STRING
# 后端读数账号（建议在 Umami 后台单独建只读用户；默认管理员 admin / umami，首次登录务必改密）
UMAMI_API_USERNAME=CHANGE_ME
UMAMI_API_PASSWORD=CHANGE_ME

# ---（以下镜像 tag 由 scripts/deploy.sh 自动写入，请勿手动维护）---
